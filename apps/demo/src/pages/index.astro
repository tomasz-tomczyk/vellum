---
import "../styles/main.css";
import { BaseLayout } from "@vellum/astro";
---

<BaseLayout
  title="vellum — a thoughtfully maintained notebook"
  description="Essays on writing, reading, and designing interfaces that don't demand attention."
  currentPath={Astro.url.pathname}
>
  <main class="ml-[260px] px-12 py-10">
    <!-- Greeting -->
    <section class="mb-14 pl-2 max-w-[42rem]">
      <div class="panel-label mb-3">May 2026 · Vol. III</div>
      <h1 class="font-display font-light text-4xl md:text-5xl lg:text-6xl leading-[1.04] text-charcoal tracking-[-0.015em]">
        A thoughtfully maintained<br />personal notebook.
      </h1>
      <p class="mt-6 text-base leading-relaxed text-charcoal max-w-[36rem]">
        Essays on writing, reading, and designing interfaces that don't demand attention.
        Updated when there's something worth saying — about once a fortnight, with longer
        pieces between seasons.
      </p>
    </section>

    <!-- Lead post -->
    <section class="mb-16 grid grid-cols-12 gap-6 items-stretch pl-2">
      <a href="/post" class="col-span-7 group">
        <div class="aspect-[16/9] rounded-lg overflow-hidden hairline relative">
          <img
            src="https://picsum.photos/seed/desk-notebook-morning-0/880/495"
            alt=""
            class="block w-full h-full object-cover"
          />
          <div class="absolute inset-0 flex items-end p-5">
            <span class="badge-mono bg-warm-white/90">Lead essay</span>
          </div>
        </div>
      </a>
      <div class="col-span-5 flex flex-col justify-center">
        <div class="panel-label mb-3">May 17 · Essay · 8 min read</div>
        <h2 class="font-display font-light text-2xl md:text-3xl leading-[1.08] text-charcoal tracking-[-0.012em]">
          <a href="/post" class="hover:text-accent">On designing calm interfaces.</a>
        </h2>
        <p class="mt-4 text-base leading-relaxed text-charcoal">
          Most software wants more from us than it gives. Here's a quieter approach — one
          that earns its place on screen by saying less, and only when asked.
        </p>
        <div class="mt-5 flex items-center gap-3 text-xs text-charcoal">
          <span>by T. Tomczyk</span>
          <span class="size-1 rounded-full bg-stone"></span>
          <a href="/post" class="btn-link">Continue reading →</a>
        </div>
      </div>
    </section>

    <!-- Recent notes list + sidebar -->
    <section class="grid grid-cols-12 gap-8 mb-16 pl-2">
      <div class="col-span-8">
        <div class="flex items-baseline justify-between mb-5 border-b border-warm-white pb-2">
          <h3 class="font-display text-xl text-charcoal">Recent notes</h3>
          <a href="#" class="panel-label hover:text-charcoal">archive →</a>
        </div>

        <ul class="divide-y divide-warm-white">
          {[
            { date: "May 12", title: "On forgiving margins.", excerpt: "Why I leave more white space than the grid says I should, and what changes when I do.", tag: "design", read: "6 min" },
            { date: "May 06", title: "Building a second brain with Markdown.", excerpt: "After two years of trying every PKM app I could install, I came back to plain text. Here's the system that finally stuck.", tag: "writing", read: "11 min" },
            { date: "Apr 28", title: "An ill-formed reckoning, literally.", excerpt: "A short defense of bad first drafts, in the company of John McPhee and a yellow legal pad.", tag: "writing", read: "4 min" },
            { date: "Apr 17", title: "Notes from a slow summer.", excerpt: "Tomatoes, swimming, three quiet weeks without the internet, and the trip I won't be taking next year.", tag: "field notes", read: "9 min" },
            { date: "Apr 04", title: "The cost of caring about typography.", excerpt: "It's not the time, exactly. It's the way every other page begins to disappoint you.", tag: "design", read: "7 min" },
          ].map((n) => (
            <li class="py-5 flex gap-5 items-baseline group">
              <span class="font-mono text-xs text-charcoal w-20 shrink-0 pt-1">{n.date}</span>
              <div class="flex-1">
                <h4 class="font-display text-xl leading-snug text-charcoal group-hover:text-accent">
                  <a href="/post">{n.title}</a>
                </h4>
                <p class="mt-1.5 text-sm text-charcoal leading-relaxed">{n.excerpt}</p>
              </div>
              <div class="hidden md:flex items-center gap-1.5 text-xs font-mono text-charcoal">
                <span class="badge">{n.tag}</span>
                <span>{n.read}</span>
              </div>
            </li>
          ))}
        </ul>

        <a href="#" class="mt-6 inline-block panel-label hover:text-charcoal">see all 142 notes →</a>
      </div>

      <!-- Sidebar -->
      <aside class="col-span-4 space-y-8 pt-1">
        <div>
          <h4 class="panel-label mb-3">Archive</h4>
          <ul class="space-y-1.5 text-sm">
            <li class="flex justify-between"><a href="#" class="text-charcoal hover:text-accent">2026</a><span class="font-mono text-xs text-charcoal">19</span></li>
            <li class="flex justify-between"><a href="#" class="text-charcoal hover:text-accent">2025</a><span class="font-mono text-xs text-charcoal">47</span></li>
            <li class="flex justify-between"><a href="#" class="text-charcoal hover:text-accent">2024</a><span class="font-mono text-xs text-charcoal">52</span></li>
            <li class="flex justify-between"><a href="#" class="text-charcoal hover:text-accent">2023</a><span class="font-mono text-xs text-charcoal">24</span></li>
          </ul>
        </div>

        <div>
          <h4 class="panel-label mb-3">Collections</h4>
          <ul class="space-y-1.5 text-sm">
            <li><a href="#" class="text-charcoal hover:text-accent">Field notebook · 2026</a></li>
            <li><a href="#" class="text-charcoal hover:text-accent">On designing things</a></li>
            <li><a href="#" class="text-charcoal hover:text-accent">Slow reading</a></li>
            <li><a href="#" class="text-charcoal hover:text-accent">Letters home</a></li>
          </ul>
        </div>

        <div>
          <h4 class="panel-label mb-3">Tags</h4>
          <div class="flex flex-wrap gap-1.5">
            {[
              ["design", 36], ["writing", 28], ["reading", 22],
              ["field notes", 18], ["typography", 12], ["tools", 9],
            ].map(([t, n]) => (
              <a class="badge hover:bg-stone/50" href="#">
                {t} <span class="font-mono text-charcoal opacity-50">{n}</span>
              </a>
            ))}
          </div>
        </div>

        <div class="card p-4">
          <h4 class="panel-label mb-2">Newsletter</h4>
          <p class="text-xs text-charcoal mb-3 leading-relaxed">
            A short letter on the last Sunday of each month. No tracking, easy to leave.
          </p>
          <form class="flex gap-2">
            <input
              type="email"
              placeholder="you@elsewhere.com"
              aria-label="Email address"
              class="flex-1 h-8 px-2.5 rounded-md bg-stone text-xs placeholder-warm-gray focus:outline-none focus:shadow-[var(--shadow-focus)]"
            />
            <button class="btn btn-primary" style="height:2rem;padding:0 0.875rem;font-size:12px">Sign up</button>
          </form>
        </div>
      </aside>
    </section>

    <!-- Reading shelf -->
    <section id="reading" class="mb-16 pl-2">
      <div class="flex items-baseline justify-between mb-5 border-b border-warm-white pb-2">
        <h3 class="font-display text-xl text-charcoal">Currently reading</h3>
        <span class="panel-label">May 2026</span>
      </div>
      <div class="grid grid-cols-5 gap-4">
        {[
          { seed: "writing-journal-1", title: "Walks with<br>Robert Walser", author: "Carl Seelig", status: "on hand", titleColor: "text-stone" },
          { seed: "library-book-2", title: "The Shape<br>of a Pocket", author: "John Berger", status: "in progress", titleColor: "text-paper" },
          { seed: "typewriter-paper-3", title: "Letters to a<br>Young Poet", author: "R. M. Rilke", status: "rereading", titleColor: "text-charcoal", authorColor: "text-charcoal" },
          { seed: "book-leather-4", title: "Four Thousand<br>Weeks", author: "O. Burkeman", status: "on hand", titleColor: "text-paper", authorColor: "text-stone" },
          { seed: "book-cover-5", title: "The<br>Notebooks", author: "L. Wittgenstein", status: "to start", titleColor: "text-charcoal", authorColor: "text-warm-gray" },
        ].map((b) => (
          <a class="group" href="#">
            <div class="aspect-[2/3] rounded-sm shadow-[var(--shadow-paper)] hairline relative overflow-hidden">
              <img src={`https://picsum.photos/seed/${b.seed}/400/600`} alt="" class="block w-full h-full object-cover" />
              <div class={`absolute inset-x-3 top-5 font-display text-sm leading-tight ${b.titleColor}`} set:html={b.title} />
              <div class={`absolute inset-x-3 bottom-4 font-mono text-xs uppercase tracking-[0.15em] ${b.authorColor ?? "text-accent"}`}>{b.author}</div>
            </div>
            <div class="mt-2 text-xs text-charcoal">{b.status}</div>
          </a>
        ))}
      </div>
    </section>

    <!-- Footer -->
    <footer class="mt-20 mb-4 pl-2 pt-6 border-t border-warm-white flex items-center justify-between text-xs font-mono text-charcoal">
      <span>© 2026 · vellum · maintained in Warsaw</span>
      <div class="flex gap-4">
        <a href="#" class="hover:text-charcoal">RSS</a>
        <a href="#" class="hover:text-charcoal">Email</a>
        <a href="#" class="hover:text-charcoal">Colophon</a>
      </div>
    </footer>
  </main>
</BaseLayout>
