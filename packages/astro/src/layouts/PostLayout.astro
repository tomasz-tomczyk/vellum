---
import BaseLayout from "./BaseLayout.astro";
import Prose from "../components/Prose.astro";

export type PostFrontmatter = {
  title: string;
  description?: string;
  date: string | Date;
  tags?: string[];
  readingTime?: string;
  cover?: string;
  related?: { title: string; href: string; cover?: string }[];
};

export type TocEntry = { id: string; text: string; depth: number };

type Props = {
  frontmatter: PostFrontmatter;
  toc?: TocEntry[];
  currentPath?: string;
};

const { frontmatter, toc = [], currentPath } = Astro.props as Props;

const dateLabel =
  typeof frontmatter.date === "string"
    ? frontmatter.date
    : frontmatter.date.toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
      });
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  currentPath={currentPath}
>
  <main class="ml-[260px] px-12 py-10 xl:mr-[300px]">
    <!-- Article header -->
    <header class="mb-10 pl-2 max-w-[42rem]">
      <div class="panel-label mb-3">
        {dateLabel}
        {frontmatter.readingTime && <span> · {frontmatter.readingTime}</span>}
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <span> · {frontmatter.tags.join(" · ")}</span>
        )}
      </div>
      <h1 class="font-display font-light text-4xl md:text-5xl leading-[1.04] text-charcoal tracking-[-0.015em]">
        {frontmatter.title}
      </h1>
      {frontmatter.description && (
        <p class="mt-6 text-base leading-relaxed text-charcoal max-w-[36rem]">
          {frontmatter.description}
        </p>
      )}
    </header>

    {frontmatter.cover && (
      <figure class="mb-12 pl-2 max-w-[42rem]">
        <div class="aspect-[16/9] rounded-lg overflow-hidden hairline">
          <img src={frontmatter.cover} alt="" class="w-full h-full object-cover" />
        </div>
      </figure>
    )}

    <div class="pl-2">
      <Prose dropcap>
        <slot />
      </Prose>
    </div>
  </main>

  <!-- Right rail -->
  <aside
    class="hidden xl:block fixed top-20 bottom-0 right-0 w-[300px] pl-8 pr-8 pt-6 pb-12 border-l border-warm-white overflow-y-auto"
  >
    {toc.length > 0 && (
      <div class="mb-10">
        <h4 class="panel-label mb-4">On this page</h4>
        <ul class="border-l border-warm-white">
          {toc.map((h) => (
            <li>
              <a
                href={`#${h.id}`}
                class={`block pl-3 py-1 text-sm text-charcoal hover:text-accent ${
                  h.depth > 2 ? "pl-6 text-xs" : ""
                }`}
              >
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="mb-10">
      <h4 class="panel-label mb-4">Quick actions</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="#" class="text-charcoal hover:text-accent">Save to reading list</a></li>
        <li><a href="#" class="text-charcoal hover:text-accent">Copy permalink</a></li>
        <li><a href="#" class="text-charcoal hover:text-accent">Print this page</a></li>
      </ul>
    </div>

    <div class="mb-10">
      <h4 class="panel-label mb-4">Metadata</h4>
      <ul class="space-y-2 text-xs font-mono text-charcoal">
        <li class="flex items-center gap-2">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="opacity-60"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/></svg>
          <span>{dateLabel}</span>
        </li>
        {frontmatter.readingTime && (
          <li class="flex items-center gap-2">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="opacity-60"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            <span>{frontmatter.readingTime}</span>
          </li>
        )}
        {frontmatter.tags?.map((t) => (
          <li class="flex items-center gap-2">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="opacity-60"><path d="M20 12 12 20l-8-8V4h8z"/><circle cx="8" cy="8" r="1.4"/></svg>
            <span>{t}</span>
          </li>
        ))}
      </ul>
    </div>

    {frontmatter.related && frontmatter.related.length > 0 && (
      <div>
        <h4 class="panel-label mb-4">Related notes</h4>
        <ul class="space-y-4">
          {frontmatter.related.map((r) => (
            <li>
              <a href={r.href} class="group flex gap-3">
                {r.cover && (
                  <div class="w-12 h-12 shrink-0 rounded-md overflow-hidden hairline">
                    <img src={r.cover} alt="" class="w-full h-full object-cover" />
                  </div>
                )}
                <span class="font-display text-sm leading-snug text-charcoal group-hover:text-accent">
                  {r.title}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </aside>
</BaseLayout>
