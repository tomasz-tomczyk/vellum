---
type Props = {
  currentPath?: string;
};

const { currentPath = "/" } = Astro.props;

// Normalize a path for active-match: strip trailing slash, strip base prefix and the leading slash.
function norm(p: string): string {
  if (!p) return "";
  const noHash = p.split("#")[0] ?? "";
  return noHash.replace(/\/+$/, "").replace(/^\/+/, "");
}

const here = norm(currentPath);

function isActive(href: string): boolean {
  const target = norm(href);
  if (target === "" && (here === "" || here === "index")) return true;
  return here === target;
}

const items: { href: string; label: string; iconPath: string }[] = [
  { href: "/", label: "Home", iconPath: "M3 11.5 12 4l9 7.5 M5 10v10h14V10" },
  { href: "/post", label: "Notes", iconPath: "M5 4h11l3 3v13H5z M16 4v3h3 M8 12h7M8 16h5" },
  { href: "/about", label: "About", iconPath: "" },
  { href: "/system", label: "System", iconPath: "" },
  { href: "/components", label: "Components", iconPath: "" },
];
---

<aside
  class="fixed top-12 bottom-0 left-0 w-[260px] pb-6 px-5 z-20 overflow-y-auto border-r border-warm-white"
>
  <!-- Wordmark -->
  <a href="/" class="font-display text-3xl tracking-tight text-charcoal block mb-10 leading-none"
    >/V.</a
  >

  <!-- Main nav -->
  <nav class="space-y-0.5 text-sm">
    <a href="/" class={`nav-item ${isActive("/") ? "font-medium" : ""}`} aria-current={isActive("/") ? "page" : undefined}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-80"><path d="M3 11.5 12 4l9 7.5"/><path d="M5 10v10h14V10"/></svg>
      <span>Home</span>
      {isActive("/") && <span class="ml-auto size-1.5 rounded-full bg-accent" aria-hidden="true" />}
    </a>
    <a href="/post" class={`nav-item ${isActive("/post") ? "font-medium" : ""}`} aria-current={isActive("/post") ? "page" : undefined}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-80"><path d="M5 4h11l3 3v13H5z"/><path d="M16 4v3h3"/><path d="M8 12h7M8 16h5"/></svg>
      <span>Notes</span>
      {isActive("/post") && <span class="ml-auto size-1.5 rounded-full bg-accent" aria-hidden="true" />}
    </a>
    <a href="#" class="nav-item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-80"><rect x="4" y="4" width="16" height="16" rx="1.5"/><path d="M4 8h16M9 4v4"/></svg>
      <span>Journal</span>
    </a>
    <a href="#" class="nav-item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-80"><path d="M3 7a1 1 0 0 1 1-1h5l2 2h8a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z"/></svg>
      <span>Projects</span>
    </a>
    <a href="/#reading" class="nav-item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-80"><path d="M3 5h7a3 3 0 0 1 3 3v12"/><path d="M21 5h-7a3 3 0 0 0-3 3"/></svg>
      <span>Reading</span>
    </a>
    <a href="#" class="nav-item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-80"><rect x="3" y="3" width="18" height="5" rx="1"/><path d="M5 8v12h14V8M10 12h4"/></svg>
      <span>Archive</span>
    </a>
    <a href="/about" class={`nav-item ${isActive("/about") ? "font-medium" : ""}`} aria-current={isActive("/about") ? "page" : undefined}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-80"><circle cx="12" cy="8" r="3.2"/><path d="M4 20c1.5-3.5 4.5-5 8-5s6.5 1.5 8 5"/></svg>
      <span>About</span>
      {isActive("/about") && <span class="ml-auto size-1.5 rounded-full bg-accent" aria-hidden="true" />}
    </a>
    <a href="/system" class={`nav-item ${isActive("/system") ? "font-medium" : ""}`} aria-current={isActive("/system") ? "page" : undefined}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-80"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2 12h3M19 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"/></svg>
      <span>System</span>
      {isActive("/system") && <span class="ml-auto size-1.5 rounded-full bg-accent" aria-hidden="true" />}
    </a>
    <a href="/components" class={`nav-item ${isActive("/components") ? "font-medium" : ""}`} aria-current={isActive("/components") ? "page" : undefined}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-80"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      <span>Components</span>
      {isActive("/components") && <span class="ml-auto size-1.5 rounded-full bg-accent" aria-hidden="true" />}
    </a>
  </nav>

  <!-- Search -->
  <div class="mt-7 flex items-center gap-2 h-9 px-3 rounded-md bg-warm-white text-sm">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="text-charcoal opacity-60"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
    <input class="flex-1 bg-transparent focus:outline-none text-charcoal placeholder-warm-gray" placeholder="Search" aria-label="Search" />
    <kbd class="font-mono text-xs text-charcoal opacity-60 tracking-tight">⌘K</kbd>
  </div>

  <!-- Theme toggle -->
  <div class="mt-3 grid grid-cols-2 gap-1 p-1 rounded-md bg-warm-white">
    <button class="rounded-[5px] py-1.5 flex items-center justify-center gap-1.5 text-xs bg-paper text-charcoal font-medium shadow-[var(--shadow-paper)]" aria-pressed="true">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4 7 17M17 7l1.4-1.4"/></svg>
      Light
    </button>
    <button class="rounded-[5px] py-1.5 flex items-center justify-center gap-1.5 text-xs text-charcoal opacity-60" aria-pressed="false">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      Dark
    </button>
  </div>

  <!-- Inspirational image -->
  <div class="mt-6 rounded-lg overflow-hidden hairline aspect-[4/3]">
    <img src="https://picsum.photos/seed/vellum-notebook/440/330" alt="" class="w-full h-full object-cover" />
  </div>

  <!-- Pull quote -->
  <blockquote class="mt-6 pl-3 border-l-2 border-accent font-display text-base leading-snug text-charcoal">
    Simplicity is not the absence of clutter, but the presence of purpose.
    <footer class="mt-2 font-mono text-xs not-italic text-charcoal tracking-[0.04em]">— John Maeda</footer>
  </blockquote>
</aside>
