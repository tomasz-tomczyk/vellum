---
import type { HTMLAttributes } from "astro/types";

type Props = {
  name?: string;
  checked?: boolean;
  disabled?: boolean;
  id?: string;
  class?: string;
} & HTMLAttributes<"input">;

const {
  name,
  checked,
  disabled,
  id,
  class: className,
  ...rest
} = Astro.props as Props;

const classes = ["checkbox", className].filter(Boolean).join(" ");
---

<input
  type="checkbox"
  class={classes}
  name={name}
  id={id}
  checked={checked}
  disabled={disabled}
  {...rest}
/>
